---
/**
 * Site-wide navigation bar using DaisyUI navbar component.
 *
 * Uses DaisyUI's dropdown + details pattern for submenus, which is
 * pure HTML/CSS — no client-side JS required.
 */
---

<div class="navbar bg-base-100 shadow-sm fixed top-0 z-50">
  <div class="navbar-start">
    {/* Mobile hamburger dropdown */}
    <div class="dropdown">
      <div tabindex="0" role="button" class="btn btn-ghost lg:hidden">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" />
        </svg>
      </div>
      <ul tabindex="0" class="menu menu-sm dropdown-content bg-base-100 rounded-box z-1 mt-3 w-52 p-2 shadow">
        <li><a href="/">Home</a></li>
        <li>
          <details>
            <summary>Lab</summary>
            <ul class="p-2">
              <li><a href="/about">About</a></li>
              <li><a href="/principal-investigator">Principal Investigator</a></li>
              <li><a href="/team">Lab Members</a></li>
              <li><a href="/alumni">Alumni</a></li>
            </ul>
          </details>
        </li>
        <li>
          <details>
            <summary>Research</summary>
            <ul class="p-2">
              <li><a href="/research">Projects</a></li>
              <li><a href="/publications">Publications</a></li>
              <li><a href="/protocol">Protocol</a></li>
            </ul>
          </details>
        </li>
        <li><a href="/news">News</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/donate">Donate</a></li>
        <li><a href="/links">Links</a></li>
      </ul>
    </div>
    <a href="/" class="btn btn-ghost text-xl text-primary">
      <img src="/img/favicon-32x32.png" alt="Logo" class="size-5" />
      Lebrun Lab
    </a>
  </div>

  {/* Desktop menu */}
  <div class="navbar-end hidden lg:flex">
    <ul class="menu menu-horizontal px-1">
      <li><a href="/">Home</a></li>
      <li>
        <div class="dropdown dropdown-hover">
          <a tabindex="0" role="button">Lab ▾</a>
          <ul tabindex="0" class="dropdown-content menu bg-base-100 rounded-box z-1 left-0 w-48 p-2 shadow">
            <li><a href="/about">About</a></li>
            <li><a href="/principal-investigator">Principal Investigator</a></li>
            <li><a href="/team">Lab Members</a></li>
            <li><a href="/alumni">Alumni</a></li>
          </ul>
        </div>
      </li>
      <li>
        <div class="dropdown dropdown-hover">
          <a tabindex="0" role="button">Research ▾</a>
          <ul tabindex="0" class="dropdown-content menu bg-base-100 rounded-box z-1 left-0 w-48 p-2 shadow">
            <li><a href="/research">Projects</a></li>
            <li><a href="/publications">Publications</a></li>
            <li><a href="/protocol">Protocol</a></li>
          </ul>
        </div>
      </li>
      <li><a href="/news">News</a></li>
      <li><a href="/contact">Contact</a></li>
      <li><a href="/donate">Donate</a></li>
      <li><a href="/links">Links</a></li>
    </ul>
  </div>
</div>
