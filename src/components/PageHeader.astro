---
/**
 * Full-width hero header using DaisyUI hero component.
 *
 * When a background image is provided, uses hero-overlay for readability.
 */

interface Props {
  title: string;
  subtitle?: string;
  image?: string;
}

const { title, subtitle, image } = Astro.props;
---

{image ? (
  <div
    class="hero min-h-64 mb-12"
    style={`background-image: url(${image});`}
  >
    <div class="hero-overlay bg-opacity-60"></div>
    <div class="hero-content text-neutral-content text-center">
      <div class="max-w-2xl">
        <h1 class="text-4xl font-bold md:text-5xl">{title}</h1>
        {subtitle && <p class="mt-3 text-lg opacity-80 md:text-xl">{subtitle}</p>}
      </div>
    </div>
  </div>
) : (
  <div class="hero min-h-48 bg-primary mb-12">
    <div class="hero-content text-primary-content text-center">
      <div class="max-w-2xl">
        <h1 class="text-4xl font-bold md:text-5xl">{title}</h1>
        {subtitle && <p class="mt-3 text-lg opacity-80 md:text-xl">{subtitle}</p>}
      </div>
    </div>
  </div>
)}
