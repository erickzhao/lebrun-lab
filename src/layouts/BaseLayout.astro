---
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import "@/styles/global.css";

interface Props {
  title?: string;
}

const { title } = Astro.props;
const pageTitle = title ? `${title} - Lebrun Lab` : "Lebrun Lab";
---

<!doctype html>
<html lang="en" data-theme="lebrun">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>

    <link rel="icon" type="image/png" href="/img/favicon-32x32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/img/favicon-256x256.png" sizes="256x256" />
    <link rel="icon" type="image/png" href="/img/favicon-512x512.png" sizes="512x512" />
  </head>
  <body>
    <Navbar />

    {/* Spacer for fixed navbar */}
    <main class="pt-16 mb-40">
      <slot />
    </main>

    <Footer />
  </body>
</html>
