---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Carousel from "@/components/Carousel";
import { getEntry, getCollection } from "astro:content";

const [homeEntry, researchTopics, researchPage, aboutPage, newsPage] = await Promise.all([
  getEntry("pages", "home"),
  getCollection("research"),
  getEntry("pages", "research-listing"),
  getEntry("pages", "about"),
  getEntry("pages", "news-listing"),
]);

if (!homeEntry) throw new Error("Home page not found");
if (!researchPage) throw new Error("Research listing page not found");
if (!aboutPage) throw new Error("About page not found");
if (!newsPage) throw new Error("News listing page not found");

const { Content: HomeContent } = await homeEntry.render();

const slides = researchTopics
  .filter((t) => t.data.headerImage)
  .map((t) => ({
    headerImage: t.data.headerImage!,
    title: t.data.title,
    slug: t.slug,
  }));

const sidebarCards = [researchPage, aboutPage, newsPage].map((page) => ({
  title: page.data.title ?? "",
  image: page.data.headerImage,
  href:
    page.id === "research-listing"
      ? "/research"
      : page.id === "news-listing"
        ? "/news"
        : `/${page.id}`,
}));
---

<BaseLayout>
  <Carousel client:load slides={slides} />

  <section class="mx-auto mt-12 max-w-6xl px-4">
    <div class="flex flex-col gap-8 lg:flex-row">
      {/* Main content */}
      <div class="prose flex-1">
        <HomeContent />
      </div>

      {/* Sidebar cards */}
      <aside class="w-full space-y-6 lg:w-80 lg:shrink-0">
        <h2 class="text-xl font-bold">Learn More</h2>
        {sidebarCards.map((card) => (
          <a href={card.href} class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow no-underline block">
            <figure>
              {card.image ? (
                <img src={card.image} alt={card.title} class="aspect-4/3 w-full object-cover" />
              ) : (
                <div class="aspect-4/3 w-full bg-info" />
              )}
            </figure>
            <div class="card-body flex-row items-center justify-between p-4">
              <span class="card-title text-primary text-base">{card.title}</span>
              <span class="btn btn-primary btn-sm">More</span>
            </div>
          </a>
        ))}
      </aside>
    </div>
  </section>
</BaseLayout>
