---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { InferGetStaticPropsType } from "astro";

export async function getStaticPaths() {
  const posts = await getCollection("news");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { post } = Astro.props as Props;
const { Content } = await post.render();
---

<BaseLayout {...(post.data.title && { title: post.data.title })}>
  <article class="mx-auto max-w-3xl px-4 pt-8">
    <header class="mb-8">
      <h1 class="text-3xl font-bold md:text-4xl">{post.data.title}</h1>
      <time
        datetime={post.data.date.toISOString()}
        class="mt-2 block text-sm opacity-70"
      >
        {post.data.date.toLocaleDateString("en-CA", {
          year: "numeric",
          month: "long",
          day: "numeric",
        })}
      </time>
      {post.data.description && (
        <p class="mt-4 text-lg opacity-70">{post.data.description}</p>
      )}
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
